<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LB Prestige Appart — Espace Client</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root{--gold:#C9A84C;--gold-light:#E8C96A;--gold-dim:#6B5520;--dark:#080808;--dark2:#0F0F0F;--dark3:#161616;--dark4:#1E1E1E;--text:#EDE8DC;--text-muted:#8A7E64;--text-dim:#3A3428;--green:#4CAF7D}
*{box-sizing:border-box;margin:0;padding:0}
html,body{min-height:100%;font-family:'Montserrat',sans-serif;background:var(--dark);color:var(--text)}
body::before{content:'';position:fixed;inset:0;background:radial-gradient(ellipse 60% 40% at 20% 10%,rgba(201,168,76,.07) 0%,transparent 60%),radial-gradient(ellipse 40% 60% at 80% 80%,rgba(201,168,76,.05) 0%,transparent 60%);pointer-events:none;z-index:0}
.grain{position:fixed;inset:0;opacity:.025;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");pointer-events:none;z-index:9999}
.wrap{position:relative;z-index:2;max-width:560px;margin:0 auto;padding:0 20px 60px}

/* LOGIN */
#login-screen{min-height:100vh;display:flex;align-items:center;justify-content:center}
.login-box{width:100%;max-width:400px;text-align:center;animation:fadeUp .8s ease}
.diamond{width:10px;height:10px;background:var(--gold);transform:rotate(45deg);margin:0 auto 28px;animation:pulse 2.5s ease-in-out infinite}
.brand{font-family:'Cormorant Garamond',serif;font-size:clamp(28px,8vw,42px);font-weight:300;letter-spacing:.12em}
.brand em{color:var(--gold);font-style:italic}
.brand-sub{font-size:9px;letter-spacing:.35em;text-transform:uppercase;color:var(--text-muted);margin-top:6px}
.gold-line{width:50px;height:1px;background:linear-gradient(90deg,transparent,var(--gold),transparent);margin:24px auto}
.login-tagline{font-family:'Cormorant Garamond',serif;font-size:16px;font-style:italic;color:var(--text-muted);margin-bottom:36px;font-weight:300}
.inp{width:100%;background:var(--dark3);border:0.5px solid rgba(201,168,76,.2);padding:15px 18px;color:var(--text);font-family:'Montserrat',sans-serif;font-size:13px;font-weight:300;outline:none;transition:border-color .3s;margin-bottom:12px;letter-spacing:.04em}
.inp:focus{border-color:rgba(201,168,76,.6)}
.inp::placeholder{color:var(--text-dim)}
.login-btn{width:100%;padding:16px;background:transparent;border:0.5px solid var(--gold);color:var(--gold);font-family:'Cormorant Garamond',serif;font-size:18px;font-style:italic;letter-spacing:.1em;cursor:pointer;position:relative;overflow:hidden;transition:color .35s;margin-top:4px}
.login-btn::before{content:'';position:absolute;inset:0;background:var(--gold);transform:translateX(-100%);transition:transform .35s cubic-bezier(.4,0,.2,1);z-index:0}
.login-btn:hover::before{transform:translateX(0)}
.login-btn:hover{color:var(--dark)}
.login-btn span{position:relative;z-index:1}
.login-err{color:#C94C4C;font-size:11px;margin-top:10px;height:14px;letter-spacing:.05em}
.login-note{font-size:10px;color:var(--text-dim);margin-top:20px;line-height:1.8;letter-spacing:.04em}

/* FORM */
#form-screen{display:none;animation:fadeUp .7s ease}
.header{text-align:center;padding:48px 0 32px}
.logo-line{display:flex;align-items:center;justify-content:center;gap:14px;margin-bottom:16px}
.logo-line::before,.logo-line::after{content:'';flex:1;height:0.5px;max-width:70px}
.logo-line::before{background:linear-gradient(90deg,transparent,var(--gold-dim))}
.logo-line::after{background:linear-gradient(90deg,var(--gold-dim),transparent)}
.logo-d{width:7px;height:7px;background:var(--gold);transform:rotate(45deg);animation:pulse 3s ease-in-out infinite}
.h-brand{font-family:'Cormorant Garamond',serif;font-size:clamp(26px,7vw,44px);font-weight:300;letter-spacing:.12em}
.h-brand em{color:var(--gold);font-style:italic}
.h-sub{font-size:9px;letter-spacing:.35em;text-transform:uppercase;color:var(--text-muted);margin-top:5px}
.h-tag{font-family:'Cormorant Garamond',serif;font-size:17px;font-style:italic;color:var(--text-muted);margin-top:22px;font-weight:300}

.amenities{display:flex;justify-content:center;gap:28px;padding:20px 0;border-top:0.5px solid rgba(201,168,76,.1);border-bottom:0.5px solid rgba(201,168,76,.1);margin:24px 0}
.am{display:flex;flex-direction:column;align-items:center;gap:6px;font-size:9px;letter-spacing:.18em;text-transform:uppercase;color:var(--text-muted)}
.am-icon{font-size:18px;color:var(--gold)}

.prices{display:flex;gap:10px;justify-content:center;margin-bottom:32px}
.price-pill{padding:9px 22px;border:0.5px solid rgba(201,168,76,.25);border-radius:40px;text-align:center}
.pt{font-size:9px;letter-spacing:.28em;text-transform:uppercase;color:var(--gold);display:block;margin-bottom:3px}
.pv{font-family:'Cormorant Garamond',serif;font-size:16px;color:var(--text)}

/* CARDS */
.card{background:var(--dark2);border:0.5px solid rgba(201,168,76,.18);padding:30px 32px;margin-bottom:16px;position:relative;overflow:hidden;animation:fadeUp .6s ease both}
.card::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--gold),transparent);opacity:.4}
.card:nth-child(1){animation-delay:.05s}
.card:nth-child(2){animation-delay:.1s}
.card:nth-child(3){animation-delay:.15s}
.card:nth-child(4){animation-delay:.2s}
.card:nth-child(5){animation-delay:.25s}
.card-lbl{font-size:9px;letter-spacing:.38em;text-transform:uppercase;color:var(--gold);margin-bottom:20px;display:flex;align-items:center;gap:10px}
.card-lbl::after{content:'';flex:1;height:0.5px;background:rgba(201,168,76,.18)}

.field{margin-bottom:18px}
.field label{display:block;font-size:10px;letter-spacing:.22em;text-transform:uppercase;color:var(--text-muted);margin-bottom:8px}
.field input,.field textarea,.field select{width:100%;background:var(--dark3);border:0.5px solid rgba(201,168,76,.15);padding:13px 15px;color:var(--text);font-family:'Montserrat',sans-serif;font-size:13px;font-weight:300;outline:none;transition:border-color .3s}
.field input:focus,.field textarea:focus,.field select:focus{border-color:rgba(201,168,76,.55)}
.field input::placeholder,.field textarea::placeholder{color:var(--text-dim)}
.field textarea{resize:vertical;min-height:90px;line-height:1.7}
.field select option{background:var(--dark3)}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:14px}

/* STARS */
.rating-row{display:flex;align-items:center;justify-content:space-between;padding:13px 0;border-bottom:0.5px solid rgba(255,255,255,.04)}
.rating-row:last-child{border-bottom:none}
.r-label{font-size:12px;letter-spacing:.04em}
.stars{display:flex;gap:5px}
.star{font-size:24px;color:var(--dark4);cursor:pointer;transition:color .12s,transform .12s;user-select:none;line-height:1}
.star:hover{transform:scale(1.15)}
.star.on{color:var(--gold)}

/* TAGS */
.tags{display:flex;flex-wrap:wrap;gap:7px}
.tag{padding:7px 14px;border:0.5px solid rgba(201,168,76,.18);font-size:10px;letter-spacing:.1em;text-transform:uppercase;cursor:pointer;color:var(--text-muted);transition:all .2s}
.tag:hover{border-color:rgba(201,168,76,.45);color:var(--text)}
.tag.on{background:rgba(201,168,76,.1);border-color:var(--gold);color:var(--gold)}

/* REC */
.rec-row{display:flex;gap:10px}
.rec-btn{flex:1;padding:14px 8px;border:0.5px solid rgba(201,168,76,.18);background:transparent;color:var(--text-muted);font-family:'Montserrat',sans-serif;font-size:11px;letter-spacing:.12em;text-transform:uppercase;cursor:pointer;transition:all .22s;display:flex;align-items:center;justify-content:center;gap:8px}
.rec-btn:hover{border-color:rgba(201,168,76,.45);color:var(--text)}
.rec-btn.on{border-color:var(--gold);color:var(--gold);background:rgba(201,168,76,.08)}

/* SUBMIT */
.submit-btn{width:100%;padding:18px;background:transparent;border:0.5px solid var(--gold);color:var(--gold);font-family:'Cormorant Garamond',serif;font-size:20px;font-style:italic;letter-spacing:.1em;cursor:pointer;position:relative;overflow:hidden;transition:color .35s;margin-top:8px}
.submit-btn::before{content:'';position:absolute;inset:0;background:var(--gold);transform:translateX(-100%);transition:transform .35s cubic-bezier(.4,0,.2,1);z-index:0}
.submit-btn:hover::before{transform:translateX(0)}
.submit-btn:hover{color:var(--dark)}
.submit-btn span{position:relative;z-index:1}

/* SUCCESS */
#success-screen{display:none;min-height:100vh;align-items:center;justify-content:center;text-align:center;padding:40px 20px}
#success-screen.show{display:flex}
.s-mark{width:72px;height:72px;border:0.5px solid var(--gold);border-radius:50%;margin:0 auto 28px;display:flex;align-items:center;justify-content:center;font-size:28px;animation:scaleIn .5s ease}
.s-title{font-family:'Cormorant Garamond',serif;font-size:34px;font-weight:300;margin-bottom:10px}
.s-sub{color:var(--text-muted);font-size:13px;line-height:1.85;font-weight:300;max-width:320px;margin:0 auto}

/* CLIENT ID BADGE */
.client-badge{display:inline-flex;align-items:center;gap:8px;padding:6px 14px;border:0.5px solid rgba(201,168,76,.3);margin-top:16px;font-size:10px;letter-spacing:.15em;color:var(--text-muted);text-transform:uppercase}
.client-badge strong{color:var(--gold)}

@keyframes fadeUp{from{opacity:0;transform:translateY(18px)}to{opacity:1;transform:translateY(0)}}
@keyframes pulse{0%,100%{transform:rotate(45deg) scale(1)}50%{transform:rotate(45deg) scale(1.5)}}
@keyframes scaleIn{from{transform:scale(.5);opacity:0}to{transform:scale(1);opacity:1}}
@media(max-width:480px){.card{padding:20px 16px}.g2{grid-template-columns:1fr}.amenities{gap:14px}}
</style>
</head>
<body>
<div class="grain"></div>

<!-- ══ LOGIN CLIENT ══ -->
<div id="login-screen">
  <div class="login-box">
    <div class="diamond"></div>
    <div class="brand">LB <em>Prestige</em> Appart</div>
    <div class="brand-sub">Kotto · Carrefour des Roses · Douala</div>
    <div class="gold-line"></div>
    <div class="login-tagline">Espace réservé à nos clients</div>
    <input class="inp" type="text" id="cl-code" placeholder="Votre code client (ex: LB-2024)" autocomplete="off" onkeydown="if(event.key==='Enter')doClientLogin()">
    <input class="inp" type="text" id="cl-name" placeholder="Votre prénom" onkeydown="if(event.key==='Enter')doClientLogin()">
    <button class="login-btn" onclick="doClientLogin()"><span>Accéder à mon espace — ✦</span></button>
    <div class="login-err" id="cl-err"></div>
    <div class="login-note">
      Votre code client vous a été transmis par le propriétaire.<br>
      Si vous ne l'avez pas reçu, contactez-nous sur WhatsApp.<br><br>
      <strong style="color:var(--text-muted)">+237 6 91 58 14 73</strong>
    </div>
  </div>
</div>

<!-- ══ FORM ══ -->
<div id="form-screen">
<div class="wrap">
  <div class="header">
    <div class="logo-line"><div class="logo-d"></div></div>
    <div class="h-brand">LB <em>Prestige</em> Appart</div>
    <div class="h-sub">Kotto · Carrefour des Roses · Douala</div>
    <div class="gold-line"></div>
    <div class="h-tag">Votre expérience, notre priorité</div>
    <div class="client-badge">Client : <strong id="display-name">—</strong> &nbsp;·&nbsp; Code : <strong id="display-code">—</strong></div>
  </div>

  <div class="amenities">
    <div class="am"><div class="am-icon">⚡</div>Wifi & Netflix</div>
    <div class="am"><div class="am-icon">🍳</div>Cuisine</div>
    <div class="am"><div class="am-icon">🚗</div>Parking</div>
    <div class="am"><div class="am-icon">🌟</div>Premium</div>
  </div>

  <div class="prices">
    <div class="price-pill"><span class="pt">Studio</span><span class="pv">25 000 FCFA / nuit</span></div>
    <div class="price-pill"><span class="pt">Appartement</span><span class="pv">35 000 FCFA / nuit</span></div>
  </div>

  <!-- SÉJOUR -->
  <div class="card">
    <div class="card-lbl">Informations séjour</div>
    <div class="g2">
      <div class="field"><label>Type de logement</label>
        <select id="f-type"><option value="">Choisir</option><option>Studio</option><option>Appartement</option></select>
      </div>
      <div class="field"><label>Durée du séjour</label>
        <select id="f-duree"><option value="">Choisir</option><option>1 nuit</option><option>2 nuits</option><option>3 nuits</option><option>4-7 nuits</option><option>Plus d'une semaine</option></select>
      </div>
    </div>
    <div class="field" style="margin-bottom:0"><label>Motif du séjour</label>
      <select id="f-motif"><option value="">Choisir</option><option>Voyage professionnel</option><option>Vacances</option><option>Événement familial</option><option>Autre</option></select>
    </div>
  </div>

  <!-- ÉVALUATION -->
  <div class="card">
    <div class="card-lbl">Évaluation détaillée</div>
    <div id="rating-rows"></div>
  </div>

  <!-- POINTS FORTS -->
  <div class="card">
    <div class="card-lbl">Points forts de votre séjour</div>
    <div class="field" style="margin-bottom:0">
      <div class="tags">
        <span class="tag" onclick="this.classList.toggle('on')">Propreté</span>
        <span class="tag" onclick="this.classList.toggle('on')">Décoration</span>
        <span class="tag" onclick="this.classList.toggle('on')">Confort</span>
        <span class="tag" onclick="this.classList.toggle('on')">Emplacement</span>
        <span class="tag" onclick="this.classList.toggle('on')">Cuisine équipée</span>
        <span class="tag" onclick="this.classList.toggle('on')">Wifi rapide</span>
        <span class="tag" onclick="this.classList.toggle('on')">Netflix</span>
        <span class="tag" onclick="this.classList.toggle('on')">Parking</span>
        <span class="tag" onclick="this.classList.toggle('on')">Calme</span>
        <span class="tag" onclick="this.classList.toggle('on')">Accueil</span>
        <span class="tag" onclick="this.classList.toggle('on')">Sécurité</span>
      </div>
    </div>
  </div>

  <!-- AMÉLIORATIONS -->
  <div class="card">
    <div class="card-lbl">Axes d'amélioration</div>
    <div class="field">
      <div class="tags">
        <span class="tag" onclick="this.classList.toggle('on')">Literie</span>
        <span class="tag" onclick="this.classList.toggle('on')">Climatisation</span>
        <span class="tag" onclick="this.classList.toggle('on')">Eau chaude</span>
        <span class="tag" onclick="this.classList.toggle('on')">Bruit</span>
        <span class="tag" onclick="this.classList.toggle('on')">Luminosité</span>
        <span class="tag" onclick="this.classList.toggle('on')">Rangements</span>
        <span class="tag" onclick="this.classList.toggle('on')">Cuisine</span>
      </div>
    </div>
    <div class="field" style="margin-bottom:0">
      <label>Commentaire libre</label>
      <textarea id="f-comment" placeholder="Partagez librement votre expérience, vos remarques, vos suggestions…"></textarea>
    </div>
  </div>

  <!-- RECOMMANDATION -->
  <div class="card">
    <div class="card-lbl">Recommandation</div>
    <div class="field" style="margin-bottom:0">
      <label>Recommanderiez-vous LB Prestige Appart ?</label>
      <div class="rec-row">
        <button class="rec-btn" id="rec-yes" onclick="setRec('yes')"><span>✦</span> Oui !</button>
        <button class="rec-btn" id="rec-maybe" onclick="setRec('maybe')"><span>◇</span> Peut-être</button>
        <button class="rec-btn" id="rec-no" onclick="setRec('no')"><span>○</span> Non</button>
      </div>
    </div>
  </div>

  <button class="submit-btn" onclick="submitForm()">
    <span>Envoyer mon avis — Merci ✦</span>
  </button>
</div>
</div>

<!-- ══ SUCCESS ══ -->
<div id="success-screen">
  <div>
    <div class="s-mark">✦</div>
    <div class="s-title">Merci infiniment</div>
    <div class="gold-line"></div>
    <div class="s-sub">Votre avis a bien été transmis.<br>Il nous aide à améliorer chaque séjour<br>au <em>LB Prestige Appart</em>.<br><br>À très bientôt à Douala !</div>
    <div style="margin-top:28px;font-size:11px;color:var(--text-dim);letter-spacing:.06em">+237 6 91 58 14 73 · +237 651 47 39 72 · +237 677 65 53 69</div>
  </div>
</div>

<script>
// ═══════════════════════════════
//  CODES CLIENTS VALIDES
//  Le propriétaire peut ajouter ici les codes qu'il crée
// ═══════════════════════════════
const VALID_CODES = [
  'LB-2024', 'LB-2025', 'LB-VIP1', 'LB-VIP2',
  'PRESTIGE1', 'PRESTIGE2', 'PRESTIGE3',
  'CLIENT01', 'CLIENT02', 'CLIENT03', 'CLIENT04', 'CLIENT05',
  'KOTTO2024', 'DOUALA01',
  'LB-001', 'LB-002', 'LB-003', 'LB-004', 'LB-005',
  'LB-006', 'LB-007', 'LB-008', 'LB-009', 'LB-010',
];

function doClientLogin() {
  const code = document.getElementById('cl-code').value.trim().toUpperCase();
  const name = document.getElementById('cl-name').value.trim();
  if (!code) { showErr('Veuillez saisir votre code client.'); return; }
  if (!name) { showErr('Veuillez saisir votre prénom.'); return; }
  if (!VALID_CODES.includes(code)) { showErr('Code client invalide. Contactez le propriétaire.'); return; }
  document.getElementById('display-name').textContent = name;
  document.getElementById('display-code').textContent = code;
  document.getElementById('login-screen').style.display = 'none';
  document.getElementById('form-screen').style.display = 'block';
  buildRatings();
}

function showErr(msg) {
  const e = document.getElementById('cl-err');
  e.textContent = msg;
  setTimeout(() => e.textContent = '', 3000);
}

const CRITERIA = ['Propreté & hygiène','Confort général','Équipements','Emplacement','Rapport qualité / prix','Accueil & communication'];
const ratings = {};
CRITERIA.forEach(c => ratings[c] = 0);

function buildRatings() {
  document.getElementById('rating-rows').innerHTML = CRITERIA.map(c => `
    <div class="rating-row">
      <span class="r-label">${c}</span>
      <div class="stars" id="s-${c.replace(/[^a-z]/gi,'_')}">
        ${[1,2,3,4,5].map(i => `<span class="star" onclick="rate('${c}',${i})">&#9733;</span>`).join('')}
      </div>
    </div>`).join('');
}

function rate(key, val) {
  ratings[key] = val;
  const id = key.replace(/[^a-z]/gi,'_');
  document.querySelectorAll(`#s-${id} .star`).forEach((s,i) => s.classList.toggle('on', i < val));
}

let rec = '';
function setRec(v) {
  rec = v;
  ['yes','maybe','no'].forEach(k => document.getElementById('rec-'+k).classList.remove('on'));
  document.getElementById('rec-'+v).classList.add('on');
}

async function submitForm() {
  const name = document.getElementById('display-name').textContent;
  const code = document.getElementById('display-code').textContent;
  const type = document.getElementById('f-type').value;
  const duree = document.getElementById('f-duree').value;
  const motif = document.getElementById('f-motif').value;
  const comment = document.getElementById('f-comment').value;

  const pointsForts = [...document.querySelectorAll('.card:nth-child(3) .tag.on')].map(t => t.textContent).join(', ');
  const ameliorations = [...document.querySelectorAll('.card:nth-child(4) .tag.on')].map(t => t.textContent).join(', ');

  const ratingsSummary = Object.entries(ratings).map(([k,v]) => `${k}: ${v}/5`).join(' | ');
  const recLabel = rec === 'yes' ? 'Oui !' : rec === 'maybe' ? 'Peut-être' : rec === 'no' ? 'Non' : 'Non précisé';

  const data = {
    _subject: `⭐ Nouvel avis client — ${name} (${code})`,
    Client: `${name} — Code: ${code}`,
    Logement: type || 'Non précisé',
    Durée: duree || 'Non précisé',
    Motif: motif || 'Non précisé',
    Évaluations: ratingsSummary,
    'Points forts': pointsForts || 'Aucun sélectionné',
    'Axes amélioration': ameliorations || 'Aucun sélectionné',
    Commentaire: comment || 'Aucun commentaire',
    Recommandation: recLabel,
  };

  try {
    await fetch('https://formspree.io/f/xbdqzgqz', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify(data)
    });
  } catch(e) {}

  document.getElementById('form-screen').style.display = 'none';
  const s = document.getElementById('success-screen');
  s.classList.add('show');
  window.scrollTo(0,0);
}
</script>
</body>
</html>
